# n8n / domain
# روی prod: N8N_HOST همان دامنه‌ی اپ است (Traefik هم از همین برای گواهی استفاده می‌کند).
# روی dev مک: N8N_PROTOCOL=http و N8N_HOST=localhost و WEBHOOK_URL=http://localhost:5678/
N8N_PROTOCOL=https
N8N_HOST=app.example.com
WEBHOOK_URL=https://app.example.com/
GENERIC_TIMEZONE=Asia/Tehran

# کلید رمزنگاری n8n — برای رمزگشایی credentialها.
# باید بین محیط‌ها یکی بماند وگرنه credentialها باز نمی‌شوند.
# از روی config مبدا (~/.n8n/config → encryptionKey) برداشته می‌شود؛ هیچ‌وقت commit نشود.
N8N_ENCRYPTION_KEY=your-n8n-encryption-key

# دامنه‌ی mongo-express (prod) — Traefik روی این دامنه سرو می‌کند.
MONGO_DOMAIN=mongo.example.com

# Traefik / ArvanCloud DNS-01 ACME (فقط prod)
# کلید API آروان برای ساختن رکورد TXT چالش. فرمت با پیشوند Apikey.
ARVANCLOUD_API_KEY="Apikey xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
# ایمیل ثبت Let's Encrypt — همین مقدار را در traefik.yml هم بگذار.
ACME_EMAIL=you@example.com

# MongoDB
MONGO_USER=n8n
MONGO_PASSWORD=change-me
MONGO_DB=n8n_db
