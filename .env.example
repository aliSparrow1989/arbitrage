# n8n / domain
# روی prod: N8N_HOST همان دامنه‌ی اپ است (Caddy هم از همین برای گواهی استفاده می‌کند).
# روی dev مک: N8N_PROTOCOL=http و N8N_HOST=localhost و WEBHOOK_URL=http://localhost:5678/
N8N_PROTOCOL=https
N8N_HOST=app.example.com
WEBHOOK_URL=https://app.example.com/
GENERIC_TIMEZONE=Asia/Tehran

# دامنه‌ی mongo-express (prod) — Caddy روی این دامنه سرو می‌کند.
MONGO_DOMAIN=mongo.example.com

# Caddy / Cloudflare DNS-01 ACME (فقط prod)
# توکن Cloudflare با دسترسی Zone:Read + DNS:Edit محدود به همین zone.
CF_API_TOKEN=your-cloudflare-api-token
ACME_EMAIL=you@example.com

# MongoDB
MONGO_USER=n8n
MONGO_PASSWORD=change-me
MONGO_DB=n8n_db
