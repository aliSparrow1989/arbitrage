# تنظیمات سراسری: گواهی TLS برای همه‌ی سایت‌ها از طریق Cloudflare DNS-01.
{
	email {$ACME_EMAIL}
	acme_dns cloudflare {env.CF_API_TOKEN}
}

# n8n — دامنه‌ی اصلی اپ.
# مسیر /images/* مستقیم از فایل‌سیستم سرو می‌شود (پیشوند /images حذف و از
# داخل /srv/images خوانده می‌شود)؛ بقیه‌ی درخواست‌ها به n8n می‌رود.
{$N8N_HOST} {
	handle_path /images/* {
		root * /srv/images
		file_server
	}
	handle {
		reverse_proxy n8n:5678
	}
}

# mongo-express — پشت basic auth خودش، روی دامنه‌ی جدا.
{$MONGO_DOMAIN} {
	reverse_proxy mongo-express:8081
}
