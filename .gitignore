# Byte-compiled / cache files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
.venv/
.env/

# Environment variables
.env

# Local config holding real API keys
config.json
*/config.json

# Data backups (large tgz dumps) — never commit
data/

# Traefik ACME storage (private key + certs) — bind mount, never commit
traefik_letsencrypt/
*.bak

# macOS
.DS_Store

# Logs
*.log

# Type checker / test caches
.mypy_cache/
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/

# Editors
.vscode/
.idea/
